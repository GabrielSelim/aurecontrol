# ============================================================
# AureControl - Configuração do Ambiente
# ============================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores abaixo
#   3. Execute: docker compose up -d --build
# ============================================================

# ─── PORTAS (ajuste para não conflitar com outros projetos) ─
FRONTEND_PORT=80
API_PORT=8000
STUDIO_PORT=3333
POSTGRES_PORT=5432

# ─── URLs PÚBLICAS ─────────────────────────────────────────
# URL pela qual o frontend será acessado
SITE_URL=https://app.seudominio.com.br
# URL pela qual a API (Kong) será acessada externamente
API_EXTERNAL_URL=https://api.seudominio.com.br
# URLs extras de redirect (separadas por vírgula)
ADDITIONAL_REDIRECT_URLS=

# ─── BANCO DE DADOS ───────────────────────────────────────
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
POSTGRES_DB=postgres

# ─── JWT / CHAVES ─────────────────────────────────────────
# Gere com: openssl rand -base64 32
JWT_SECRET=TROQUE_jwt_secret_minimo_32_caracteres
JWT_EXPIRY=3600

# Gere as chaves em: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# Use o JWT_SECRET acima como input
ANON_KEY=TROQUE_anon_key_gerada
SERVICE_ROLE_KEY=TROQUE_service_role_key_gerada

# ─── REALTIME ─────────────────────────────────────────────
# Gere com: openssl rand -base64 48
SECRET_KEY_BASE=TROQUE_secret_key_base_minimo_64_caracteres

# ─── SMTP (E-mail) ────────────────────────────────────────
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_USER=noreply@seudominio.com.br
SMTP_PASS=TROQUE_smtp_password
SMTP_ADMIN_EMAIL=noreply@seudominio.com.br
SMTP_SENDER_NAME=AureControl
